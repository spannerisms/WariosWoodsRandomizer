<!--

##################################################################################################
##################################################################################################
################### Formats
##################################################################################################
##################################################################################################


##################################################################################################
### Color codes
##################################################################################################

hex: rrggbb                   Example: CCCCFF

##################################################################################################
### Colors
##################################################################################################
<color name="[unique name]" light="[color code]" dark="[color code]" />

##################################################################################################
### Palettes
##################################################################################################
<palette name="[unique name]">
	<body type="[type]" ...
	<gloss type="[type]" ...
	<blush type="[type]" ...
</palette>

body, gloss, blush tags:
	named colors:
		<body type="namedcolor" name="[color name]" />

	explicit colors:
		<body type="inlinecolor" light="[color code]" dark="[color code]" />

Not recommended to add:
	<suboutline type="inlinecolor" color="[color code]" />

##################################################################################################
### Themes
##################################################################################################
<theme name="[unique name]">
	<red type="[type]" ...
	<yellow type="[type]" ...
	<green type="[type]" ...
	<blue type="[type]" ...
	<pink type="[type]" ...
	<azure type="[type]" ...
	<black type="[type]" ...
	<white type="[type]" ...
</theme>

color tags:
	named palettes:
		<red type="namedpalette" palettename="[palette name]" />

	inline palettes:
		<red type="childpalette">
			{ see Palettes format }
		</red>

##################################################################################################
##################################################################################################
##################################################################################################
-->
